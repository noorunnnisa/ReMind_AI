<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#CCCCFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#373737" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Soothing Content"
            android:textColor="#4A3FA0"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/profile_circle_bg"
            android:contentDescription="Profile"
            android:src="@drawable/profile" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:id="@+id/mainContentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardComfortInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvComfortModeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Caregiver Comfort Mode"
                        android:textColor="#4A3FA0"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvComfortModeDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Use familiar sounds, photos, and calming content when the patient is restless, confused, or anxious."
                        android:textColor="#6E7E8C"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecommendedNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#F9E5EC"
                app:cardCornerRadius="26dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:id="@+id/recommendedContentLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/tvRecommendedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended Now"
                        android:textColor="#4A3FA0"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNowPlayingTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Favorite Dua"
                        android:textColor="#2C3442"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNowPlayingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Spiritual comfort content"
                        android:textColor="#6E7E8C"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:id="@+id/playerStatusBox"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/edittext_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <TextView
                            android:id="@+id/tvPlayerStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ready to play"
                            android:textColor="#6E7E8C"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="04:00"
                            android:textColor="#4A3FA0"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectSurahLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Select Quran Surah"
                        android:textColor="#6E7E8C"
                        android:textSize="13sp" />

                    <Spinner
                        android:id="@+id/spSurah"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/edittext_bg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaySurah"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="Play Selected Surah"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        app:backgroundTint="#4A3FA0"
                        app:cornerRadius="26dp" />

                    <LinearLayout
                        android:id="@+id/playerButtonRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPlayNow"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Play Now"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            app:backgroundTint="#6F54B5"
                            app:cornerRadius="27dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStop"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Stop"
                            android:textAllCaps="false"
                            android:textColor="#6F54B5"
                            android:textSize="16sp"
                            app:backgroundTint="#FFFFFF"
                            app:cornerRadius="27dp"
                            app:strokeColor="#6F54B5"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvComfortLibraryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Comfort Library"
                android:textColor="#4A3FA0"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/comfortLibraryLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalmMusic"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    app:cardBackgroundColor="#EFE9FF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivCalmMusicIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#FFFFFF"
                            android:contentDescription="Calm music"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_media_play" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCalmMusicTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calm Music"
                                android:textColor="#2C3442"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCalmMusicDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Soft sounds for relaxation"
                                android:textColor="#6E7E8C"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFamilyPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#FFF7E0"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivFamilyPhotosIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#FFFFFF"
                            android:contentDescription="Family photos"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_gallery" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFamilyPhotosTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Family Photos"
                                android:textColor="#2C3442"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvFamilyPhotosDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Familiar faces and memories"
                                android:textColor="#6E7E8C"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGentleVideo"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#E4F0FF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivGentleVideoIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#FFFFFF"
                            android:contentDescription="Gentle video"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_media_ff" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvGentleVideoTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gentle Video"
                                android:textColor="#2C3442"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvGentleVideoDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Peaceful visuals for comfort"
                                android:textColor="#6E7E8C"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFavoriteDua"
                    android:layout_width="match_parent"
                    android:layout_height="86dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#E0F5F8"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivFavoriteDuaIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="#FFFFFF"
                            android:contentDescription="Favorite dua"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_info_details" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvFavoriteDuaTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Favorite Dua"
                                android:textColor="#2C3442"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvFavoriteDuaDescription"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Spiritual comfort content"
                                android:textColor="#6E7E8C"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddContent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Add New Comfort Content"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                app:backgroundTint="#6F54B5"
                app:cornerRadius="28dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
